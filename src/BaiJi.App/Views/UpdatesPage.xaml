<Page
    x:Class="BaiJi.App.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" MaxWidth="480">
        <TextBlock x:Name="VersionText" />
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch x:Name="AutoToggle" Toggled="OnAutoToggled" />
            <TextBlock x:Name="AutoLabel" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="CheckButton" Click="OnCheck" />
            <Button x:Name="RestartButton" Click="OnRestart" Visibility="Collapsed"
                    Style="{ThemeResource AccentButtonStyle}" />
        </StackPanel>
        <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </StackPanel>
</Page>
