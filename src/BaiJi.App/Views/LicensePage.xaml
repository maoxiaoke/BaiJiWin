<Page
    x:Class="BaiJi.App.Views.LicensePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" MaxWidth="480">
        <!-- Inactive state -->
        <StackPanel x:Name="InactivePanel" Spacing="12">
            <HyperlinkButton x:Name="GetKeyLink" Click="OnGetKey" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="KeyBox" Width="300" TextChanged="OnKeyChanged" />
                <Button x:Name="ActivateButton" Click="OnActivate" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Active state -->
        <StackPanel x:Name="ActivePanel" Spacing="10" Visibility="Collapsed">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusRowLabel" Grid.Column="0" />
                <TextBlock x:Name="StatusRowValue" Grid.Column="1" HorizontalAlignment="Right"
                           Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
            </Grid>
            <TextBlock x:Name="KeyRow" />
            <TextBlock x:Name="ExpiryRow" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="ManageButton" Click="OnManage" />
                <Button x:Name="DeactivateButton" Click="OnDeactivate" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Page>
